{
  "name": "@lass-lang/plugin-utils",
  "version": "0.0.1",
  "description": "Shared utilities for Lass bundler plugins",
  "author": "Long-lazuli",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "husky": "^9.1.7",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "keywords": [
    "lass",
    "plugin",
    "utilities",
    "bundler",
    "vite",
    "bun"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lass-lang/plugin-utils.git"
  },
  "bugs": {
    "url": "https://github.com/lass-lang/plugin-utils/issues"
  },
  "homepage": "https://github.com/lass-lang/plugin-utils#readme"
}
